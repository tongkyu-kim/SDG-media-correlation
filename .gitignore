# System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Node modules (if any future JS build tools are added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Data files (except examples and templates)
src/oda/*.csv
src/oda/*.xlsx
src/raw/*.xlsx
src/raw/*.xls
src/raw/*.csv
src/processed/*
src/news/
src/news_processed/*
src/labels/*.csv
src/termlist/*.xls
src/termlist/*.xlsx
src/validation/*
!src/oda/.gitkeep
!src/raw/.gitkeep
!src/processed/.gitkeep
!src/labels/.gitkeep
!src/news_processed/.gitkeep
!src/validation/.gitkeep

# Labeling sheets in docs/ — share via Google Sheets, not git
docs/*.csv
docs/*.xlsx

# Trained model weights (can be hundreds of MB)
models/
pipeline/models/
*.bin
*.safetensors
*.pt
*.pth

# Log files
*.log

# Temporary files
tmp/
temp/

# Build outputs (if any future build process is added)
dist/
build/

# Python virtualenv
pipeline/.venv/
.venv/
__pycache__/
*.pyc
*.pyo

# HuggingFace model cache
pipeline/.cache/
.cache/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# AWS SSH key pairs — never commit private keys
*.pem
s3_contents.txt

# Personal session notes — references AWS account/instance IDs
SESSION_CONTEXT.md
