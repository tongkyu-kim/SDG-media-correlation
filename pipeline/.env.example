# BigKinds login credentials (optional but recommended to avoid rate limiting)
BIGKINDS_EMAIL=your@email.com
BIGKINDS_PASSWORD=yourpassword

# Where to write daily JSON files
# Default resolves to <project_root>/src/news/ automatically — only set this
# if you want to override the output location.
# NEWS_DATA_DIR=../src/news

# Collection settings
COLLECT_START_DATE=2010-01-01   # how far back backfill.py goes
DAILY_REQUEST_DELAY=2.0         # seconds between page requests
MAX_RETRIES=3
